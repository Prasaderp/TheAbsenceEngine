# ── App ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:test1234@localhost:5432/absence_engine
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=300
DB_POOL_PRE_PING=true

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
ARQ_REDIS_URL=redis://localhost:6379/1

# ── S3 / MinIO ────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=documents
S3_REGION=us-east-1

# ── Auth ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-secret-change-in-production-use-64-char-random-string-here-xx
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM ──────────────────────────────────────────────────────────────
LLM_PRIMARY_PROVIDER=gemini
GEMINI_API_KEY=                    # REQUIRED — get from https://aistudio.google.com
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_FALLBACK_CHAIN=openai,anthropic
LLM_MAX_RETRIES=3
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_TIMEOUT=60
LLM_MAX_TOKENS_PER_ANALYSIS=50000

# ── Embeddings ────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_ANALYSIS=5/minute
RATE_LIMIT_GENERAL=60/minute
